🚀 Step 11 — GitHub Actions Workflow

name: Multi Job Docker CI

on:

  push:
    branches:
      - main

  pull_request:
    branches:
      - main

  workflow_dispatch:

env:
  TAG: ${{ github.sha }}

jobs:

  backend:

    runs-on: ubuntu-latest

    steps:

      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build Backend Image
        run: docker build -t binayadevops/kutu-backend:${TAG} ./backend

      - name: Push Backend Image
        run: docker push binayadevops/kutu-backend:${TAG}

  frontend:

    needs: backend

    runs-on: ubuntu-latest

    steps:

      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build Frontend Image
        run: docker build -t binayadevops/kutu-frontend:${TAG} ./frontend

      - name: Push Frontend Image
        run: docker push binayadevops/kutu-frontend:${TAG}

