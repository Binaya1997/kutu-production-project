🚀 Step 6 — Docker Compose Setup

Create docker-compose.yml

services:

  postgres:

    image: postgres:16

    container_name: postgres-container

    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: admin123
      POSTGRES_DB: kutu_db

    ports:
      - '5432:5432'

    volumes:
      - postgres-data:/var/lib/postgresql/data

  backend:

    build: ./backend

    container_name: backend-container

    ports:
      - '5000:5000'

    depends_on:
      - postgres

  frontend:

    build: ./frontend

    container_name: frontend-container

    ports:
      - '8080:80'

    depends_on:
      - backend

volumes:
  postgres-data:

